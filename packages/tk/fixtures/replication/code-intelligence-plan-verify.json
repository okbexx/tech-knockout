{
  "id": "code-intelligence-plan-verify",
  "capability": "local code intelligence MCP",
  "from": "codegraph,gitnexus",
  "limit": 5,
  "expect": {
    "referenceIds": ["codegraph", "gitnexus"],
    "verificationContract": "local-code-intelligence-mcp:v1",
    "verifyStatus": "warn",
    "checkStatuses": {
      "plan_schema_valid": "pass",
      "reference_projects_present": "pass",
      "kernel_present": "pass",
      "verification_contract_present": "pass",
      "source_backing": "warn"
    },
    "warningIncludes": ["Source cache missing for: codegraph, gitnexus"],
    "minCounts": {
      "kernel": 2,
      "mustKeep": 2,
      "canAdapt": 2,
      "risks": 3
    },
    "traceSteps": ["resolve_references", "build_plan", "verify"],
    "traceArtifactsByStep": {
      "resolve_references": ["references.json"],
      "build_plan": ["plan.json", "brief.md"],
      "verify": ["verification.json"]
    },
    "artifactFiles": ["brief.md", "input.json", "plan.json", "references.json", "trace.json", "verification.json"]
  }
}
