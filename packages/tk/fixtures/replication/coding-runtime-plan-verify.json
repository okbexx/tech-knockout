{
  "id": "coding-runtime-plan-verify",
  "capability": "durable coding agent runtime",
  "from": "jcode,opencode",
  "limit": 5,
  "expect": {
    "referenceIds": ["jcode", "opencode"],
    "verificationContract": "durable-coding-agent-runtime:v1",
    "verifyStatus": "warn",
    "checkStatuses": {
      "plan_schema_valid": "pass",
      "reference_projects_present": "pass",
      "kernel_present": "pass",
      "verification_contract_present": "pass",
      "source_backing": "warn"
    },
    "warningIncludes": ["Source cache missing for: jcode, opencode"],
    "minCounts": {
      "kernel": 6,
      "mustKeep": 8,
      "canAdapt": 6,
      "risks": 5
    },
    "traceSteps": ["resolve_references", "build_plan", "verify"],
    "traceArtifactsByStep": {
      "resolve_references": ["references.json"],
      "build_plan": ["plan.json", "brief.md"],
      "verify": ["verification.json"]
    },
    "artifactFiles": ["brief.md", "input.json", "plan.json", "references.json", "trace.json", "verification.json"]
  }
}
