{
  "id": "graphrag-plan-verify",
  "capability": "GraphRAG retrieval kernel",
  "from": "lightrag,ragflow",
  "limit": 5,
  "expect": {
    "referenceIds": ["lightrag", "ragflow"],
    "verificationContract": "graphrag-retrieval-kernel:v1",
    "verifyStatus": "warn",
    "checkStatuses": {
      "plan_schema_valid": "pass",
      "reference_projects_present": "pass",
      "kernel_present": "pass",
      "verification_contract_present": "pass",
      "source_backing": "warn"
    },
    "warningIncludes": ["Source cache missing for: lightrag, ragflow"],
    "minCounts": {
      "kernel": 2,
      "mustKeep": 2,
      "canAdapt": 2,
      "risks": 3
    },
    "traceSteps": ["resolve_references", "build_plan", "verify"],
    "traceArtifactsByStep": {
      "resolve_references": ["references.json"],
      "build_plan": ["plan.json", "brief.md"],
      "verify": ["verification.json"]
    },
    "artifactFiles": ["brief.md", "input.json", "plan.json", "references.json", "trace.json", "verification.json"]
  }
}
