{
  "name": "@jarl_okbe/tk",
  "version": "0.1.1",
  "private": false,
  "description": "Technical Knockout CLI, MCP server, and Codex installer for capability replication.",
  "type": "module",
  "bin": {
    "tk": "bin/tk.mjs",
    "tk-mcp-server": "mcp/server.mjs"
  },
  "files": [
    ".mcp.json",
    "README.md",
    "bin/",
    "data/",
    "lib/",
    "mcp/",
    "schemas/",
    "scripts/"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "homepage": "https://github.com/okbexx/tech-knockout",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/okbexx/tech-knockout.git",
    "directory": "packages/tk"
  },
  "bugs": {
    "url": "https://github.com/okbexx/tech-knockout/issues"
  },
  "license": "MIT",
  "keywords": [
    "technical-knockout",
    "codex",
    "mcp",
    "skills",
    "capability-replication",
    "architecture",
    "build-vs-buy",
    "technical-research",
    "agent-context"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "doctor": "node ./bin/tk.mjs doctor",
    "catalog:build": "node ./bin/tk.mjs catalog build",
    "catalog:validate": "node ./bin/tk.mjs catalog validate",
    "codex:install:dry-run": "node ./bin/tk.mjs codex install --dry-run",
    "mcp:smoke": "node ./scripts/mcp-smoke.mjs",
    "check": "node --check ./bin/tk.mjs && node --check ./lib/tk-core.mjs && node --check ./mcp/server.mjs && node --check ./scripts/mcp-smoke.mjs",
    "verify": "npm run check && npm run catalog:validate && npm run codex:install:dry-run && npm run doctor && npm run mcp:smoke"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "commander": "^15.0.0",
    "env-paths": "^4.0.0",
    "zod": "^4.4.3"
  }
}
