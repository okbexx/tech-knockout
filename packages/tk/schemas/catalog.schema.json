{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/okbexx/tech-knockout/schemas/catalog.schema.json",
  "title": "Technical Knockout Catalog",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "projects", "comparisons"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string" },
    "projects": {
      "type": "array",
      "items": { "$ref": "#/$defs/project" }
    },
    "comparisons": {
      "type": "array",
      "items": { "$ref": "#/$defs/comparison" }
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "required": [
        "id",
        "name",
        "report",
        "dependencySummary",
        "dependencies",
        "dependencyEvidencePresent",
        "dependencyEvidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "repo": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] },
        "cloneUrl": { "type": ["string", "null"] },
        "report": { "type": "string" },
        "reportFile": { "type": "string" },
        "category": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] },
        "adoption": { "type": ["string", "null"] },
        "architectureValue": { "type": ["integer", "null"], "minimum": 1, "maximum": 5 },
        "license": { "type": ["string", "null"] },
        "language": { "type": ["string", "null"] },
        "analysisDate": { "type": ["string", "null"] },
        "sourceDir": { "type": ["string", "null"] },
        "owner": { "type": ["string", "null"] },
        "sourceExists": { "type": "boolean" },
        "dependencySummary": { "$ref": "#/$defs/dependencySummary" },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency" }
        },
        "dependencyEvidencePresent": { "type": "boolean" },
        "dependencyEvidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependencyEvidence" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "dependencySummary": {
      "type": "object",
      "required": ["total", "manifests", "byEcosystem", "byScope"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "manifests": { "type": "integer", "minimum": 0 },
        "byEcosystem": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "byScope": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "dependency": {
      "type": "object",
      "required": ["name", "version", "ecosystem", "scope", "manifest"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": ["string", "null"] },
        "ecosystem": { "type": "string" },
        "scope": { "type": "string" },
        "manifest": { "type": "string" }
      }
    },
    "dependencyEvidence": {
      "type": "object",
      "required": ["dependency", "type", "usedFor", "problemSolved", "evidence", "reuseSignal", "caution"],
      "properties": {
        "dependency": { "type": "string" },
        "type": { "type": "string" },
        "usedFor": { "type": "string" },
        "problemSolved": { "type": "string" },
        "evidence": { "type": "string" },
        "reuseSignal": { "type": "string" },
        "caution": { "type": "string" }
      }
    },
    "comparison": {
      "type": "object",
      "required": ["id", "path", "title"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "title": { "type": "string" }
      }
    }
  }
}
