{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://okbexx.github.io/technical-knockout/schemas/report-structure-audit.schema.json",
  "title": "TK Report Structure Audit",
  "type": "object",
  "required": ["schemaVersion", "contractVersion", "generatedAt", "reportRoot", "summary", "reports"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "contractVersion": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "reportRoot": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "required": ["totalReports", "passedReports", "warnedReports", "failedReports", "warningCount", "errorCount"],
      "properties": {
        "totalReports": { "type": "integer", "minimum": 0 },
        "passedReports": { "type": "integer", "minimum": 0 },
        "warnedReports": { "type": "integer", "minimum": 0 },
        "failedReports": { "type": "integer", "minimum": 0 },
        "warningCount": { "type": "integer", "minimum": 0 },
        "errorCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "title",
          "status",
          "missingH2",
          "missingRequiredH3",
          "missingRecommendedH3",
          "missingBottomArchitectureChildren",
          "headings",
          "errors",
          "warnings"
        ],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
          "missingH2": { "type": "array", "items": { "type": "string" } },
          "missingRequiredH3": {
            "type": "object",
            "additionalProperties": { "type": "array", "items": { "type": "string" } }
          },
          "missingRecommendedH3": {
            "type": "object",
            "additionalProperties": { "type": "array", "items": { "type": "string" } }
          },
          "missingBottomArchitectureChildren": {
            "type": "array",
            "items": { "type": "string" }
          },
          "headings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["level", "line", "title", "canonicalTitle"],
              "properties": {
                "level": { "type": "integer", "enum": [2, 3, 4] },
                "line": { "type": "integer", "minimum": 1 },
                "title": { "type": "string", "minLength": 1 },
                "canonicalTitle": { "type": "string", "minLength": 1 },
                "parentH2": { "type": ["string", "null"] },
                "parentH3": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            }
          },
          "errors": {
            "type": "array",
            "items": { "$ref": "#/$defs/issue" }
          },
          "warnings": {
            "type": "array",
            "items": { "$ref": "#/$defs/issue" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "required": ["severity", "code", "message"],
      "properties": {
        "severity": { "type": "string", "enum": ["error", "warning"] },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "section": { "type": "string" },
        "parent": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "sections": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
